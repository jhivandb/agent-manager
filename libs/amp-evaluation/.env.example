# ============================================================================
# AMP-Eval Configuration Template
# ============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values in the .env file
# 3. The .env file is gitignored and will not be committed
# ============================================================================

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================
# Identifies the agent being evaluated

AMP_AGENT_UID=my-agent
AMP_ENVIRONMENT_UID=production

# ============================================================================
# TRACE SOURCE
# ============================================================================
# Path to a local trace JSON file for offline evaluation.
# For live traces from the platform API, pass an explicit TraceFetcher
# instance with a token_provider to the runner constructor.

AMP_TRACE_FILE_PATH=./data/traces.json

# ============================================================================
# LLM-AS-JUDGE (Optional)
# ============================================================================
# Default model for built-in LLM judge evaluators.
# Individual evaluators can override with: builtin("helpfulness", model="gpt-4o")

AMP_LLM_JUDGE_DEFAULT_MODEL=gpt-4o-mini

# LLM provider API keys (read directly by the LLM provider SDKs)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# ============================================================================
# OPENTELEMETRY (For Experiment runner — agent invocation tracing)
# ============================================================================

TRACELOOP_API_ENDPOINT=http://localhost:22893/otel
TRACELOOP_KEY=your_traceloop_key_here
